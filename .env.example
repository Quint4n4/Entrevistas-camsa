# Plantilla de variables de entorno. Copia este archivo como `.env` y rellena los valores.
# Para generar SECRET_KEY:  python -c "import secrets; print(secrets.token_urlsafe(50))"

# --- Django ---
DEBUG=True
SECRET_KEY=cambia-esto-por-una-llave-secreta
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Base de datos (PostgreSQL) ---
POSTGRES_DB=entrevista
POSTGRES_USER=entrevista
POSTGRES_PASSWORD=cambia-esta-contrasena
DATABASE_URL=postgres://entrevista:cambia-esta-contrasena@db:5432/entrevista

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5173
